	partition _Calendar = calculated
		mode: import
		source =
				
				VAR StartDate = CALCULATE(MIN(FactMain[date]), all(FactMain[date]))  -- Set your start date
				VAR EndDate = CALCULATE(MAX(FactMain[date]), all(FactMain[date])) -- Set your end date
				RETURN
				ADDCOLUMNS(
				    CALENDAR(StartDate, EndDate),
				    "Year", YEAR([Date]),
				    "Quarter", "Q" & QUARTER([Date])&"-"&YEAR([Date]),
				    "Month", FORMAT([Date], "MMMM"),
				    "MonthNumber", MONTH([Date]),
				    "Week", WEEKNUM([Date]),
				    "YearMonth", FORMAT([Date], "MMM-YYYY"),
				    "Day", DAY([Date]),
				    "DayOfWeek", FORMAT([Date], "dddd"),
				    "StartOfWeek", [Date] - WEEKDAY([Date], 2) + 1,  -- Monday as the start of the week
				    "EndOfWeek", [Date] - WEEKDAY([Date], 2) + 7,    -- Sunday as the end of the week
				    "StartOfMonth", EOMONTH([Date], -1) + 1,         -- First day of the month
				    "EndOfMonth", EOMONTH([Date], 0),                  -- Last day of the month
				    "OrderMonth", (year([Date])*100) + MONTH([Date]),
				    "OrderQuarter", (YEAR([Date])*10) + QUARTER([Date])
				)

	annotation PBI_Id = 4045f4cb3c9e41668c0dba40b759bb09

