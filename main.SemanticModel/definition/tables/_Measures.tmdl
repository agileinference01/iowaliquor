		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '0102_Sales Amount' = sum(GoalMain[sale_dollars])
		lineageTag: 01452009-00c4-44df-8217-91f7812e017e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure '0104_Cost of Goods Sold' = SUMX(GoalMain, GoalMain[state_bottle_cost]*GoalMain[bottles_sold])
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 2051b8de-07da-4f2f-aa1a-79654333a078

	measure '0105_Gross Profit' = [0102_Sales Amount]-[0104_Cost of Goods Sold]
		formatString: \$#,0.###############;(\$#,0.###############);\$#,0.###############
		lineageTag: 6462911a-de9d-443e-aeb9-6229ca2f8749

	measure '0106_Gross Margin Pct' = ```
			
			 var _num = [0105_Gross Profit]
			 var _den = [0102_Sales Amount]
			 RETURN
			 DIVIDE( _num, _den, BLANK())
			```
		formatString: 0.00%;-0.00%;0.00%
		lineageTag: 62c8dfb4-657b-40b5-a62b-c939c5a7b87d

	measure '0107_Selected Measure Actual' = ```
			
			var _sel = SELECTEDVALUE(_Metrics[Name], "Sales")
			
			RETURN
			SWITCH(_sel,
			"Bottles Sold", [0100_Number of Bottles Sold],
			"Bottle Volume Sold", [0101_Bottle Volume Sold],
			"Sales", [0102_Sales Amount],
			"Cost of Goods Sold", [0104_Cost of Goods Sold],
			"Gross Profit", [0105_Gross Profit],
			"Gross Margin Pct", [0106_Gross Margin Pct]
			)
			
			```
		lineageTag: cd79f7ca-1adc-4ac5-9bf4-64dfa5c648cd

		formatStringDefinition =
