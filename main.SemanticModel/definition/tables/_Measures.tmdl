	measure '0001_Max Date' = max(_Calendar[Date])
		formatString: General Date
		lineageTag: 417f98fb-e2b7-4042-8215-0c7bda5dd3d9

	measure '0002_Min Date' = MIN(_Calendar[Date])
		formatString: General Date
		lineageTag: bf68e67a-b7ea-47cb-bc0c-787add00b090

	measure '0108_Minimum Date for Current Period' =
			
			var _min = [0002_Min Date]
			var _max = [0001_Max Date]
			var _interval = SELECTEDVALUE(_Intervals[Interval])
			var _datefiltered = ISFILTERED(_Calendar[Date])
			var _monthfiltered = ISFILTERED(_Calendar[YearMonth])
			var _nonfiltered =
			SWITCH(_interval,
			"Daily", _max-1,
			"Weekly", WeekStart(_max),
			"Monthly", MonthStart(_max),
			"Quarterly", QuarterStart(_max),
			"Yearly", YearStart(_max)
			)
			var _filtered =
			SWITCH(_interval,
			"Daily", [0002_Min Date]-1,
			"Weekly", WeekStart(_min),
			"Monthly", MonthStart(_min),
			"Quarterly", QuarterStart(_min),
			"Yearly", YearStart(_min)
			)
			RETURN
			if(_datefiltered=TRUE() || _monthfiltered=TRUE(), _filtered, _nonfiltered)
		formatString: General Date
		lineageTag: 400dd193-bb90-4739-94ae-e9097cc1f657

	measure '0109_Maximum Date for Previous Period' = ```
			
			var _min = [0110_Minimum Date for Previous Period]
			var _max = [0108_Minimum Date for Current Period]
			var _diff = DATEDIFF(_min, _max, DAY)
			var _interval = SELECTEDVALUE(_Intervals[Interval])
			var _datefiltered = ISFILTERED(_Calendar[Date])
			var _monthfiltered = ISFILTERED(_Calendar[YearMonth])
			var _maxdate = if(_datefiltered=TRUE() || _monthfiltered=TRUE(), _max, _min+_diff)
			
			RETURN
			_maxdate-1
			
			```
		formatString: General Date
		lineageTag: b2e5f75c-13ec-4ce9-bfda-22d5159a1ef6

	measure '0110_Minimum Date for Previous Period' =
			
			var _min = [0002_Min Date]
			var _max = [0108_Minimum Date for Current Period]-1
			var _interval = SELECTEDVALUE(_Intervals[Interval])
			var _datefiltered = ISFILTERED(_Calendar[Date])
			var _monthfiltered = ISFILTERED(_Calendar[YearMonth])
			var _nonfiltered =
			SWITCH(_interval,
			"Daily", _max-1,
			"Weekly", WeekStart(_max-6),
			"Monthly", EOMONTH(_max+1,-2)+1,
			"Quarterly", QuarterStart(_max-91),
			"Yearly", date(YEAR(_max+1)-1,1,1)
			)
			var _filtered =
			SWITCH(_interval,
			"Daily", [0002_Min Date]-1,
			"Weekly", WeekStart(_min-7),
			"Monthly", MonthStart(_min-30),
			"Quarterly", QuarterStart(_min-92),
			"Yearly", YearStart(_min)
			)
			
			RETURN
			if(_datefiltered=TRUE() || _monthfiltered=TRUE(), _filtered, _nonfiltered)
		formatString: General Date
		lineageTag: 629136be-589b-404c-a6d7-4d2a281f84bc

	measure '0111_Selected Measure Actual CP' = ```
			
			 var _max = [0001_Max Date]
			 var _min = [0108_Minimum Date for Current Period]
			 
			 RETURN
			 CALCULATE( [0107_Selected Measure Actual], 
			 FILTER(GoalMain, GoalMain[date]>=_min && GoalMain[date]<=_max)
			 )
			```
		lineageTag: c4413549-5bb6-40bc-905e-dbeaec1da6bd

		formatStringDefinition =
				var _sel = SELECTEDVALUE(_Metrics[Name])
				RETURN
				FormatMeasure(_sel)

	measure '0112_Moving Average Goal' = ```
			
			VAR CurrentDate =
			    MAX ( '_Calendar'[Date] )  -- Get the current date in context
			VAR StartDate =
			    [0108_Minimum Date for Current Period] - 90     -- Go back 180 days
			RETURN
			CALCULATE (
			    SUMX (
			        VALUES ( '_Calendar'[Date] ),  -- Iterate over each date in the range
			        [0107_Selected Measure Actual]             -- Replace with your base measure (e.g., [Total Sales])
			    ),
			    FILTER (
			        ALL ( _Calendar ),
			        _Calendar[Date] > StartDate &&
			        _Calendar[Date] <= CurrentDate
			    )
			)
			
			```
		lineageTag: 0db599b0-417f-4681-9fc8-e3cbe439f76d

		annotation PBI_FormatHint = {"isGeneralNumber":true}

