table _Measures
	lineageTag: a9f69190-f3cd-4eff-9344-718aff4d1d2a

	measure 0000_Blank = BLANK()
		formatString: 0
		lineageTag: e2dfe859-b2c8-44a5-958f-58ff3831383c

	measure '0100_Number of Bottles Sold' = sum(GoalMain[bottles_sold])
		formatString: #,0
		lineageTag: 7574c851-ab32-45a8-a753-e50191c8ad17

	measure '0101_Bottle Volume Sold' = sum(GoalMain[volume_sold_liters])
