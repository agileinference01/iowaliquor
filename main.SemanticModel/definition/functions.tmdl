function WeekStart =
		(_date : DATETIME) =>
		        _date - WEEKDAY(_date,2) + 1
	lineageTag: 38379cfe-4a35-4ff9-80d8-25a76826d571

function MonthStart =
		(_date : DATETIME) =>
		        EOMONTH(_date,-1) + 1
	lineageTag: c5ce77ed-b645-4e8e-a4f9-2811227adfe3

function QuarterStart =
		(_date : DATETIME) =>
		        var _month = (3*INT((MONTH(_date)-1)/3))+1
		        RETURN
		        DATE(YEAR(_date), _month, 1)
	lineageTag: 9702e772-a824-4f0c-a45e-b4f589bd14ca

function YearStart =
		(_date : DATETIME) =>
		        DATE(YEAR(_date),1,1)
	lineageTag: 29765f63-dafa-4e55-bc0b-1eaf0885b2d3

function QuarterNumber =
		(_date : DATETIME) =>
		        (INT((MONTH(_date)-1)/3))+1
	lineageTag: 54d5b2fa-53f0-442a-9f41-c6f3c95b04ee

function FormatMeasure =
		(_sel : STRING) =>
				VAR _type = GetMetricType(_sel)
				VAR _number =
					SWITCH(_sel,
					"Bottles Sold", "###,###,###,###.00",
					"Bottle Volume Sold", "###,###,###,###.00L",
					"Sales", "$###,###,###,###.00",
					"Cost of Goods Sold", "$###,###,###,###.00",
					"Gross Profit", "$###,###,###,###.00",
					"Gross Margin Pct", "0.00%"
					)
				RETURN
					_number
	lineageTag: 30799d9c-97e0-4ff9-8cfe-7360a6dfdda6

function MeasureDirection =
		(_sel : STRING) =>
		        CALCULATE(
					FIRSTNONBLANK(_Metrics[Direction],1),
					FILTER(_Metrics, _Metrics[Name]=_sel)
				)
	lineageTag: 89848359-08b3-44d9-9f75-fcf41cd48f5e

function PercentToGoal =
		(_actual : NUMERIC, _goal : NUMERIC, _sel : STRING) =>
		        VAR _dir = MeasureDirection(_sel)
				var _pos = DIVIDE(_actual, _goal, BLANK())
				VAR _neg = 2-_pos
		        RETURN
		            SWITCH(TRUE(),
		            _dir = "Negative",_neg,
		            _dir = "Positive", _pos
		            )
	lineageTag: db0494ab-f166-44ce-a22b-41e1ba300099

function GetMetricType =
		(_sel : STRING) =>
		        CALCULATE(
					FIRSTNONBLANK(_Metrics[Format],1),
					FILTER(_Metrics, _Metrics[Name]=_sel)
				)
	lineageTag: 209c1416-07cb-47d6-b4c2-84d7985356ba

function ShortenNumber = ```
		(_number : NUMERIC, _sel: STRING) =>
				VAR _type = GetMetricType(_sel)
				var _amount = 
					SWITCH(TRUE(),
					ABS(_number)>1000000000, FORMAT(_number/1000000000, "###,###,###,###.00") & "B",
					ABS(_number)>1000000, FORMAT(_number/1000000, "###,###,###,###.00") & "M",
					ABS(_number)>1000, FORMAT(_number/1000, "###,###,###,###.00") & "K",
					_number
					)
				RETURN
					if(_type="Percent", FORMAT(_number, "Percent"), _amount)
		```
	lineageTag: 8ed8fd7b-398e-4241-a7ae-31ff67540931

function DirectionArrow =
		(_pct : NUMERIC, _sel : STRING) =>
			VAR _dir = MeasureDirection(_sel)
			RETURN
			IF(_pct >= 1, UNICHAR(9650),UNICHAR(9660))
	lineageTag: 565dd9fc-e3b7-4230-a086-ca66593fe845

function DirectionColor =
		(_pct : NUMERIC) =>
				SWITCH(TRUE(),
				_pct >= 1, "#008053",
				_pct >=.95, "#FFCE00",
				"#FD4F43"
				)
	lineageTag: 23e37ec5-5f77-44a0-96c1-972606999d9b

function DeltaArrow =
		(_pct : NUMERIC, _sel : STRING) =>
			VAR _dir = MeasureDirection(_sel)
			var _pos = SWITCH(TRUE(),
				_pct > 0, UNICHAR(129157),
				_pct < 0, UNICHAR(129158),
				unichar(129154)
				)
			var _neg = SWITCH(TRUE(),
				_pct < 0, UNICHAR(129157),
				_pct > 0, UNICHAR(129158),
				unichar(129154)
				)
		    RETURN
			if(_dir = "Positive", _pos, _neg)
	lineageTag: 4f3bc247-4192-4867-a329-901c5178a949

function DeltaColor =
		(_pct : NUMERIC, _sel : STRING) =>
				VAR _dir = MeasureDirection(_sel)
				VAR _pos =
				SWITCH(TRUE(),
				_pct >= 0, "#008053",
				"#FD4F43"
				)
				VAR _neg =
				SWITCH(TRUE(),
				_pct >= 0, "#FD4F43",
				"#008053"
				)
				RETURN
				if(_dir = "Positive", _pos, _neg)
	lineageTag: 0b3d6a43-0150-409b-b4e5-5082542a1de2

